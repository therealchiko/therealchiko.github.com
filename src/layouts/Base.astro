---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Writing about making things well in a world that's moving fast."
} = Astro.props;

const fullTitle = title === 'Home'
  ? 'Chiko Mukwenha'
  : `${title} | Chiko Mukwenha`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <ViewTransitions />
    <script is:inline>
      // Theme: light by default. Dark only when explicitly toggled.
      function applyTheme() {
        var d = document.documentElement.classList;
        if (localStorage.getItem('theme') === 'dark') {
          d.add('dark');
        } else {
          d.remove('dark');
        }
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body>
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
    <ThemeToggle />
  </body>
</html>

<style>
  .site-main {
    max-width: var(--layout-content);
    margin: 0 auto;
    padding: var(--space-xl) var(--layout-padding) var(--space-section);
  }
</style>
