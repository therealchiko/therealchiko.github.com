---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import SEO from '../components/SEO.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  publishedDate?: Date;
}

const {
  title,
  description = "Writing about making things well in a world that's moving fast.",
  type = 'website',
  publishedDate,
} = Astro.props;

const fullTitle = title === 'Home'
  ? 'Chiko Mukwenha'
  : `${title} | Chiko Mukwenha`;

const url = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="Chiko Mukwenha" href="/rss.xml" />
    <title>{fullTitle}</title>
    <SEO
      title={fullTitle}
      description={description}
      url={url}
      type={type}
      publishedDate={publishedDate}
    />
    <ViewTransitions />
    <script is:inline>
      // Theme: light by default. Dark only when explicitly toggled.
      function applyTheme() {
        var d = document.documentElement.classList;
        if (localStorage.getItem('theme') === 'dark') {
          d.add('dark');
        } else {
          d.remove('dark');
        }
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HE58P37FGF"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HE58P37FGF');
    </script>
  </head>
  <body>
    <Header />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
    <ThemeToggle />
  </body>
</html>

<style>
  .site-main {
    max-width: var(--layout-content);
    margin: 0 auto;
    padding: var(--space-xl) var(--layout-padding) var(--space-section);
  }
</style>
