---
/*
 * PostList
 *
 * Displays posts as: title ... date (dotted leader between).
 * Used on the writing archive and homepage.
 */
interface Post {
  slug: string;
  data: {
    title: string;
    date: Date;
  };
}

interface Props {
  posts: Post[];
  basePath?: string;
}

const { posts, basePath = '/writing' } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}
---

<ul class="post-list">
  {posts.map((post) => (
    <li>
      <a href={`${basePath}/${post.slug}/`} class="post-link">
        <span class="post-title">{post.data.title}</span>
        <span class="post-leader" aria-hidden="true"></span>
        <time class="post-date" datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
      </a>
    </li>
  ))}
</ul>

<style>
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .post-link {
    display: flex;
    align-items: baseline;
    gap: var(--space-xs);
    padding: var(--space-xs) 0;
    text-decoration: none;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .post-link:hover {
    color: var(--color-accent);
  }

  .post-title {
    flex-shrink: 0;
  }

  .post-leader {
    flex: 1;
    border-bottom: 1px dotted var(--color-border);
    min-width: var(--space-lg);
    margin-bottom: 0.25em;
  }

  .post-date {
    flex-shrink: 0;
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-variant-numeric: tabular-nums;
  }
</style>
