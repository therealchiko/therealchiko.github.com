---
/*
 * Footer
 *
 * Primary site navigation lives here.
 * Small caps, separated by middle dots.
 */
const navItems = [
  { href: '/writing/', label: 'Writing' },
  { href: '/now/', label: 'Now' },
  { href: '/about/', label: 'About' },
];

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <nav class="footer-nav">
    {navItems.map((item, i) => (
      <>
        <a href={item.href}>{item.label}</a>
        {i < navItems.length - 1 && <span class="separator">·</span>}
      </>
    ))}
  </nav>
  <p class="copyright">&copy; {year} Chiko Mukwenha</p>
</footer>

<style>
  .site-footer {
    max-width: var(--layout-content);
    margin: 0 auto;
    padding: var(--space-section) var(--layout-padding) var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .footer-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .footer-nav a {
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    font-variant-caps: all-small-caps;
    letter-spacing: 0.02em;
    text-decoration: none;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--color-text);
  }

  .separator {
    color: var(--color-border);
    font-size: var(--font-size-sm);
    user-select: none;
  }

  .copyright {
    text-align: center;
    font-family: var(--font-ui);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
